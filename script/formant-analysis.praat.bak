# ==========================================
# Formant 분석 (Command Line Version)
# Arguments:
#   1) inputSound$   : wav path
#   2) outputFile$   : txt path
#   3) max_formant   : Maximum formant (Hz)
#   4) num_formants  : Number of formants to track
#   5) window_length : Window length (s)
# ==========================================

form Formant Analysis
    sentence inputSound
    sentence outputFile
    real max_formant 5500
    natural num_formants 5
    real window_length 0.025
endform

# 0) 파일에서 Sound 로드
Read from file: inputSound$
soundID = selected("Sound")
soundName$ = selected$("Sound")

# 음성 파일의 기본 정보
duration = Get total duration
sampling_rate = Get sampling frequency

# 1) Formant 객체 생성
selectObject: soundID
To Formant (burg): 0, num_formants, max_formant, window_length, 50
formantID = selected("Formant")

# 2) 각 포먼트의 통계값 계산
f1_mean = Get mean: 1, 0, 0, "hertz"
f1_sd = Get standard deviation: 1, 0, 0, "hertz"

f2_mean = Get mean: 2, 0, 0, "hertz"
f2_sd = Get standard deviation: 2, 0, 0, "hertz"

f3_mean = Get mean: 3, 0, 0, "hertz"
f3_sd = Get standard deviation: 3, 0, 0, "hertz"

f4_mean = Get mean: 4, 0, 0, "hertz"
f4_sd = Get standard deviation: 4, 0, 0, "hertz"

# 3) 시간별 샘플링 (0.01초 간격)
time_step = 0.01
num_samples = floor(duration / time_step)

# F1/F2 비율 계산 (모음 공간 분석용)
f1f2_ratio = f1_mean / f2_mean

# 4) 포먼트 대역폭 (Bandwidth) 분석
selectObject: formantID
b1_mean = Get mean: 1, 0, 0, "hertz"
b2_mean = Get mean: 2, 0, 0, "hertz"
b3_mean = Get mean: 3, 0, 0, "hertz"

# 5) 결과 판정
feedback$ = ""
status$ = "정상 (Normal)"

# 포먼트 값 평가 (성인 화자 기준)
if f1_mean < 300 or f1_mean > 1000
    status$ = "확인 필요 (Check Required)"
    feedback$ = feedback$ + newline$ + "⚠️ [F1 이상]: F1 평균값이 일반적 범위를 벗어났습니다." + newline$
    feedback$ = feedback$ + "   👉 입의 개구도(열림 정도)를 조절하여 모음을 더 명확히 발음하세요." + newline$
endif

if f2_mean < 800 or f2_mean > 3000
    status$ = "확인 필요 (Check Required)"
    feedback$ = feedback$ + newline$ + "⚠️ [F2 이상]: F2 평균값이 일반적 범위를 벗어났습니다." + newline$
    feedback$ = feedback$ + "   👉 혀의 전후 위치를 조절하여 조음 위치를 개선하세요." + newline$
endif

if f1_sd > 150 or f2_sd > 300
    status$ = "확인 필요 (Check Required)"
    feedback$ = feedback$ + newline$ + "⚠️ [포먼트 변동성 높음]: 포먼트 값의 표준편차가 높아 조음이 불안정합니다." + newline$
    feedback$ = feedback$ + "   👉 일정한 혀 위치와 입 모양을 유지하며 발음 연습을 하세요." + newline$
endif

if status$ == "정상 (Normal)"
    feedback$ = "✅ 포먼트 값이 정상 범위 내에 있으며 조음이 안정적입니다."
endif

# 6) 결과를 파일로 저장
writeFileLine: outputFile$, "=== 포먼트 분석 결과 ==="
appendFileLine: outputFile$, "음성 파일: ", soundName$
appendFileLine: outputFile$, "지속 시간: ", fixed$(duration, 3), " 초"
appendFileLine: outputFile$, "샘플링 레이트: ", sampling_rate, " Hz"
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "상태: ", status$
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 포먼트 주파수 (Hz) ==="
appendFileLine: outputFile$, "F1 평균: ", fixed$(f1_mean, 2), " Hz (표준편차: ", fixed$(f1_sd, 2), " Hz)"
appendFileLine: outputFile$, "F2 평균: ", fixed$(f2_mean, 2), " Hz (표준편차: ", fixed$(f2_sd, 2), " Hz)"
appendFileLine: outputFile$, "F3 평균: ", fixed$(f3_mean, 2), " Hz (표준편차: ", fixed$(f3_sd, 2), " Hz)"
appendFileLine: outputFile$, "F4 평균: ", fixed$(f4_mean, 2), " Hz (표준편차: ", fixed$(f4_sd, 2), " Hz)"
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 포먼트 대역폭 (Bandwidth) ==="
appendFileLine: outputFile$, "B1 평균: ", fixed$(b1_mean, 2), " Hz"
appendFileLine: outputFile$, "B2 평균: ", fixed$(b2_mean, 2), " Hz"
appendFileLine: outputFile$, "B3 평균: ", fixed$(b3_mean, 2), " Hz"
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 모음 공간 지표 ==="
appendFileLine: outputFile$, "F1/F2 비율: ", fixed$(f1f2_ratio, 4)
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 피드백 및 솔루션 ==="
appendFileLine: outputFile$, feedback$
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 참고 사항 ==="
appendFileLine: outputFile$, "• F1: 입의 개구도(열림)와 관련 (낮을수록 입이 닫힘)"
appendFileLine: outputFile$, "• F2: 혀의 전후 위치와 관련 (높을수록 전설모음)"
appendFileLine: outputFile$, "• F3: 입술 모양과 관련"
appendFileLine: outputFile$, "• 표준편차가 낮을수록 조음이 안정적"

# 7) 시간별 포먼트 추적 데이터 추가
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 시간별 포먼트 추적 (처음 10개 샘플) ==="
appendFileLine: outputFile$, "시간(s)", tab$, "F1(Hz)", tab$, "F2(Hz)", tab$, "F3(Hz)"

selectObject: formantID
for i from 1 to min(10, num_samples)
    time = i * time_step
    if time <= duration
        f1_val = Get value at time: 1, time, "hertz", "Linear"
        f2_val = Get value at time: 2, time, "hertz", "Linear"
        f3_val = Get value at time: 3, time, "hertz", "Linear"
        
        if f1_val != undefined and f2_val != undefined and f3_val != undefined
            appendFileLine: outputFile$, fixed$(time, 3), tab$, fixed$(f1_val, 1), tab$, fixed$(f2_val, 1), tab$, fixed$(f3_val, 1)
        endif
    endif
endfor

# 8) 객체 정리
selectObject: formantID
Remove
selectObject: soundID
Remove
