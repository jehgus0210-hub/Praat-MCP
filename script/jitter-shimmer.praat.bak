# ==========================================
# Jitter & Shimmer 분석 (Command Line Version)
# Arguments:
#   1) inputSound$   : wav path
#   2) outputFile$   : txt path
#   3) jitter_Threshold
#   4) shimmer_Threshold
#   5) pitch_Floor
#   6) pitch_Ceiling
# ==========================================

form Batch Jitter Shimmer Analysis
    sentence inputSound
    sentence outputFile
    real jitter_Threshold 1.04
    real shimmer_Threshold 3.81
    natural pitch_Floor 75
    natural pitch_Ceiling 600
endform

# 0) 파일에서 Sound 로드
Read from file: inputSound$
soundID = selected("Sound")

# 1) 분석
selectObject: soundID
To Pitch (cc): 0, pitch_Floor, 15, "no", 0.03, 0.45, 0.01, 0.35, 0.14, pitch_Ceiling
pitchID = selected("Pitch")

selectObject: soundID
plusObject: pitchID
To PointProcess (cc)
ppID = selected("PointProcess")

jitter = Get jitter (local): 0, 0, 0.0001, 0.02, 1.3
jitter_percent = jitter * 100

selectObject: soundID
plusObject: ppID
shimmer = Get shimmer (local): 0, 0, 0.0001, 0.02, 1.3, 1.6
shimmer_percent = shimmer * 100

selectObject: soundID
To Harmonicity (cc): 0.01, pitch_Floor, 0.1, 1.0
hnrID = selected("Harmonicity")
hnr_mean = Get mean: 0, 0

# 임시 객체 정리
selectObject: pitchID
plusObject: ppID
plusObject: hnrID
Remove

# 2) 판정/피드백
feedback$ = ""
status$ = "통과 (Normal)"

if jitter_percent > jitter_Threshold
    status$ = "재연습 필요 (Check Required)"
    feedback$ = feedback$ + newline$ + "⚠️ [Jitter 높음]: 성대 진동의 주기(음높이)가 불규칙합니다." + newline$
    feedback$ = feedback$ + "   👉 솔루션: 목에 힘을 빼고, 입술 트릴(Lip trill)이나 허밍으로 일정한 음을 길게 유지하세요." + newline$
endif

if shimmer_percent > shimmer_Threshold
    status$ = "재연습 필요 (Check Required)"
    feedback$ = feedback$ + newline$ + "⚠️ [Shimmer 높음]: 목소리의 크기(진폭)가 불규칙하거나 바람 새는 소리가 납니다." + newline$
    feedback$ = feedback$ + "   👉 솔루션: 복식 호흡으로 호흡 압력을 일정하게 유지하고 '아'를 명확히 내보세요." + newline$
endif

if hnr_mean < 20
    note_hnr$ = "(참고: HNR이 20dB보다 낮으면 쉰 목소리가 섞여 있을 수 있습니다.)"
else
    note_hnr$ = "(HNR 수치 양호)"
endif

if status$ == "통과 (Normal)"
    feedback$ = "✅ 모든 수치가 정상 범위 내에 있습니다."
endif

# 3) 결과를 파일로 저장
writeFileLine: outputFile$, "=== 음성 분석 결과 ==="
appendFileLine: outputFile$, "상태: ", status$
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "1. Jitter (local): ", fixed$(jitter_percent, 3), "% (기준: ", jitter_Threshold, "% 이하)"
appendFileLine: outputFile$, "2. Shimmer (local): ", fixed$(shimmer_percent, 3), "% (기준: ", shimmer_Threshold, "% 이하)"
appendFileLine: outputFile$, "3. HNR (Mean): ", fixed$(hnr_mean, 3), " dB ", note_hnr$
appendFileLine: outputFile$, ""
appendFileLine: outputFile$, "=== 피드백 및 솔루션 ==="
appendFileLine: outputFile$, feedback$

# 4) Sound 객체 정리
selectObject: soundID
Remove
